# OncoCorr — Environment Configuration
# Copy this file to .env.local and fill in your keys.
#
# .env.local is git-ignored — your keys will NEVER be committed.
# You only need ONE key to get live AI responses. Priority order:
#   Groq → DeepSeek → Gemini → OpenRouter → Ollama (local) → Demo mode
#
# ─── Free AI Providers ───────────────────────────────────────────────────────
#
# 1. GROQ — Free tier: 14,400 req/day · Llama 3.3 70B
#    Get key: https://console.groq.com (no credit card required)
VITE_GROQ_API_KEY=your_groq_api_key_here

# 2. DEEPSEEK — Cheapest paid: ~$0.14/1M tokens · DeepSeek-V3
#    Get key: https://platform.deepseek.com
VITE_DEEPSEEK_API_KEY=

# 3. GEMINI — Free tier: 1M tokens/day · Gemini 1.5 Flash
#    Get key: https://aistudio.google.com (no credit card required)
VITE_GEMINI_API_KEY=

# 4. OPENROUTER — Free models: Llama 3.1, Gemma 3, Mistral
#    Get key: https://openrouter.ai (no credit card required)
#    Free models: meta-llama/llama-3.1-8b-instruct:free, google/gemma-3-12b-it:free
VITE_OPENROUTER_API_KEY=
# Override the default free model (optional):
# VITE_OPENROUTER_MODEL=google/gemma-3-27b-it:free

# 5. OLLAMA — Local models, completely free, no key needed
#    Install: https://ollama.ai — then run: ollama pull llama3.2
#    (Automatically detected if running at localhost:11434)
# VITE_OLLAMA_URL=http://localhost:11434
# VITE_OLLAMA_MODEL=llama3.2

# ─── Free Bioinformatics APIs (no key required) ──────────────────────────────
# PubMed  — https://eutils.ncbi.nlm.nih.gov (literature search)
# GEO     — https://www.ncbi.nlm.nih.gov/geo (omics datasets)
# STRING  — https://string-db.org/api (protein interactions)
